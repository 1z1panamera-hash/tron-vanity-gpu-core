          tron_payload25_compare(payload25, prefixRange.high) <= 0;
 }
 
+__device__ __noinline__ int tron_payload21_with_tail_compare(
+    const uint8_t payload21[21],
+    const uint8_t value25[25],
+    uint8_t tailByte) {
+  for (int i = 0; i < 21; ++i) {
+    if (payload21[i] < value25[i]) return -1;
+    if (payload21[i] > value25[i]) return 1;
+  }
+  for (int i = 21; i < 25; ++i) {
+    if (tailByte < value25[i]) return -1;
+    if (tailByte > value25[i]) return 1;
+  }
+  return 0;
+}
+
+__device__ __noinline__ bool tron_payload21_can_match_prefix_range(
+    const uint8_t payload21[21],
+    const TronPrefixRange prefixRange) {
+  return tron_payload21_with_tail_compare(payload21, prefixRange.low, 0xff) >= 0 &&
+         tron_payload21_with_tail_compare(payload21, prefixRange.high, 0x00) <= 0;
+}
+
 __device__ __noinline__ uint64_t tron_payload25_mod_base58_power(
     const uint8_t payload25[25],
     uint64_t modulus) {
@@ -226,18 +248,32 @@ __device__ __noinline__ int tron_base58_payload25(const uint8_t payload25[25], c
   return ret_pos;
 }
 
-__device__ __noinline__ void tron_payload25_from_public_key64(
+__device__ __noinline__ void tron_payload21_from_public_key64(
     const uint8_t public_key64[64],
-    uint8_t payload25[25]) {
+    uint8_t payload21[21]) {
   uint8_t digest[32];
-  uint8_t checksum[4];
   tron_keccak256_64(public_key64, digest);
-  payload25[0] = 0x41;
-  for (int i = 0; i < 20; ++i) payload25[i + 1] = digest[i + 12];
-  tron_checksum4(payload25, checksum);
+  payload21[0] = 0x41;
+  for (int i = 0; i < 20; ++i) payload21[i + 1] = digest[i + 12];
+}
+
+__device__ __noinline__ void tron_payload25_from_payload21(
+    const uint8_t payload21[21],
+    uint8_t payload25[25]) {
+  uint8_t checksum[4];
+  for (int i = 0; i < 21; ++i) payload25[i] = payload21[i];
+  tron_checksum4(payload21, checksum);
   for (int i = 0; i < 4; ++i) payload25[21 + i] = checksum[i];
 }
 
+__device__ __noinline__ void tron_payload25_from_public_key64(
+    const uint8_t public_key64[64],
+    uint8_t payload25[25]) {
+  uint8_t payload21[21];
+  tron_payload21_from_public_key64(public_key64, payload21);
+  tron_payload25_from_payload21(payload21, payload25);
+}
