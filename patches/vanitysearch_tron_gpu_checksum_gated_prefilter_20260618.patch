+  const int first = host_base58_value('T');
+  const int second = host_base58_value(prefix_after_t);
+  if (first < 0 || second < 0) throw std::runtime_error("invalid Base58 prefix");
+
+  uint32_t prefix_value = static_cast<uint32_t>(first) * 58U + static_cast<uint32_t>(second);
+  if (!big25_add_small(range.low, prefix_value)) throw std::runtime_error("prefix low overflow");
+  if (!big25_add_small(range.high, prefix_value + 1U)) throw std::runtime_error("prefix high overflow");
+  for (int i = 0; i < 32; ++i) {
