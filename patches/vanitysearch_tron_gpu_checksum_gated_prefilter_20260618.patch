   tron_public_key64_from_xy(px, py, public_key64);
-  tron_payload25_from_public_key64(public_key64, payload25);
+  tron_payload21_from_public_key64(public_key64, payload21);
+  if (!tron_payload21_can_match_prefix_range(payload21, prefixRange)) {
