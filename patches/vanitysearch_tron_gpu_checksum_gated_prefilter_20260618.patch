+}
+
+static bool host_big25_add_small(uint8_t value[25], uint32_t addend) {
+  uint32_t carry = addend;
+  for (int i = 24; i >= 0 && carry > 0; --i) {
+    uint32_t sum = (uint32_t)value[i] + (carry & 0xff);
+    value[i] = (uint8_t)(sum & 0xff);
+    carry = (carry >> 8) + (sum >> 8);
+  }
+  return carry == 0;
+}
+
+static bool host_big25_sub_one(uint8_t value[25]) {
+  for (int i = 24; i >= 0; --i) {
+    if (value[i] > 0) {
+      --value[i];
+      return true;
+    }
+    value[i] = 0xff;
+  }
+  return false;
+}
