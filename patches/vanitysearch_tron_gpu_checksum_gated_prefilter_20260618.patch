+static bool host_tron_prefix_range(char prefixAfterT, TronPrefixRange *range) {
+  int first = host_tron_base58_value('T');
+  int second = host_tron_base58_value(prefixAfterT);
+  if (first < 0 || second < 0) return false;
+
+  memset(range->low, 0, sizeof(range->low));
+  memset(range->high, 0, sizeof(range->high));
+
+  uint32_t prefixValue = (uint32_t)first * 58U + (uint32_t)second;
+  if (!host_big25_add_small(range->low, prefixValue)) return false;
+  if (!host_big25_add_small(range->high, prefixValue + 1U)) return false;
+
+  for (int i = 0; i < 32; ++i) {
+    if (!host_big25_mul_small(range->low, 58U)) return false;
+    if (!host_big25_mul_small(range->high, 58U)) return false;
+  }
+  return host_big25_sub_one(range->high);
+}
