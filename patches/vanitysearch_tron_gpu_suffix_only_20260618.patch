+    "duration_seconds_limit": seconds,
+    "gpu_grid": grid,
+    "return_code": rc,
+    "timeout_reached": rc == 124,
+    "samples": len(matches),
+    "reported_total_mkey_s": total_mkey_s,
+    "reported_gpu_mkey_s": gpu_mkey_s,
+    "candidate_attempts_per_second_estimate": gpu_mkey_s * 1_000_000.0,
+    "notes": [
+        "This is a bounded RunPod GPU Pod benchmark signal, not final Serverless P90 proof.",
+        "TRON_SUPPRESS_SECRET_OUTPUT=1 is required and was set by the script.",
+        "Use only TEST patterns; do not use customer patterns or customer data.",
+        "Final production delivery must use the Python wrapper and age encryption."
