diff --git a/GPU/GPUTronVectorCheck.cu b/GPU/GPUTronVectorCheck.cu
new file mode 100644
index 0000000..b7bddd2
--- /dev/null
+++ b/GPU/GPUTronVectorCheck.cu
@@ -0,0 +1,349 @@
+/*
+ * RunPod-only CUDA correctness check for TRON address construction.
+ *
+ * This uses public TEST_ONLY public-key vectors. It does not generate private
+ * keys, does not search, and does not benchmark.
+ */
+
+#include <cuda_runtime.h>
+
+#include <cstdint>
+#include <cstdio>
+#include <cstring>
+#include <stdexcept>
+#include <string>
+#include <vector>
+
+#include "GPUHash.h"
+#include "GPUTron.h"
+
+struct TronVectorInput {
+  uint8_t public_key64[64];
+  uint64_t x[4];
+  uint64_t y[4];
+  char expected_address[48];
+  char suffix5[6];
+  char wrong_suffix5[6];
+};
+
+struct TronVectorResult {
+  int passed;
+  int address_len;
+  int match_rule_passed;
+  int wrong_rule_rejected;
+  int suffix_prefilter_passed;
+  int wrong_suffix_prefilter_rejected;
+  int suffix_fast_prefilter_passed;
+  int wrong_suffix_fast_prefilter_rejected;
+  int suffix_checksum_word_prefilter_passed;
+  int wrong_suffix_checksum_word_prefilter_rejected;
+  int xy_payload_passed;
+  char computed_address[48];
+  uint8_t payload25[25];
+};
+
+__global__ void tron_vector_kernel(
+    const TronVectorInput *inputs,
+    TronVectorResult *results,
+    int count) {
+  int idx = blockIdx.x * blockDim.x + threadIdx.x;
+  if (idx >= count) return;
+
+  TronVectorResult result{};
+  result.address_len =
+      tron_address_from_public_key64(inputs[idx].public_key64, result.computed_address, result.payload25);
+  result.match_rule_passed = tron_match_suffix5(
+      result.computed_address,
+      result.address_len,
+      inputs[idx].suffix5) ? 1 : 0;
+  result.wrong_rule_rejected = !tron_match_suffix5(
+      result.computed_address,
+      result.address_len,
+      inputs[idx].wrong_suffix5) ? 1 : 0;
+  uint8_t payload21[21];
+  tron_payload21_from_public_key64(inputs[idx].public_key64, payload21);
+  uint8_t xy_payload21[21];
+  tron_payload21_from_xy(inputs[idx].x, inputs[idx].y, xy_payload21);
+  result.xy_payload_passed = 1;
+  for (int i = 0; i < 21; ++i) {
+    if (payload21[i] != xy_payload21[i]) {
+      result.xy_payload_passed = 0;
+      break;
+    }
+  }
+  uint64_t suffix_value = tron_suffix5_value(inputs[idx].suffix5);
+  uint64_t wrong_suffix_value = tron_suffix5_value(inputs[idx].wrong_suffix5);
+  result.suffix_prefilter_passed =
+      tron_payload25_matches_suffix5(result.payload25, suffix_value) ? 1 : 0;
+  result.wrong_suffix_prefilter_rejected =
+      !tron_payload25_matches_suffix5(result.payload25, wrong_suffix_value) ? 1 : 0;
+  uint8_t checksum4[4];
+  tron_checksum4(payload21, checksum4);
+  result.suffix_fast_prefilter_passed =
+      tron_payload21_checksum_matches_suffix5(payload21, checksum4, suffix_value) ? 1 : 0;
+  result.wrong_suffix_fast_prefilter_rejected =
+      !tron_payload21_checksum_matches_suffix5(payload21, checksum4, wrong_suffix_value) ? 1 : 0;
+  uint32_t checksum4_be32 = tron_checksum4_be32(payload21);
+  result.suffix_checksum_word_prefilter_passed =
+      (tron_payload21_checksum_word_matches_suffix5(payload21, checksum4_be32, suffix_value) &&
+       tron_payload21_checksum_fused_matches_suffix5(payload21, suffix_value)) ? 1 : 0;
+  result.wrong_suffix_checksum_word_prefilter_rejected =
+      (!tron_payload21_checksum_word_matches_suffix5(payload21, checksum4_be32, wrong_suffix_value) &&
+       !tron_payload21_checksum_fused_matches_suffix5(payload21, wrong_suffix_value)) ? 1 : 0;
+  result.passed = 1;
+  for (int i = 0; i < 48; ++i) {
+    if (result.computed_address[i] != inputs[idx].expected_address[i]) {
+      result.passed = 0;
+      break;
+    }
+    if (inputs[idx].expected_address[i] == 0) break;
+  }
+  if (!result.match_rule_passed ||
+      !result.wrong_rule_rejected ||
+      !result.suffix_prefilter_passed ||
+      !result.wrong_suffix_prefilter_rejected ||
+      !result.suffix_fast_prefilter_passed ||
+      !result.wrong_suffix_fast_prefilter_rejected ||
+      !result.suffix_checksum_word_prefilter_passed ||
+      !result.wrong_suffix_checksum_word_prefilter_rejected ||
+      !result.xy_payload_passed) {
+    result.passed = 0;
+  }
+  results[idx] = result;
+}
+
+static uint8_t hex_value(char c) {
+  if (c >= '0' && c <= '9') return static_cast<uint8_t>(c - '0');
+  if (c >= 'a' && c <= 'f') return static_cast<uint8_t>(c - 'a' + 10);
+  if (c >= 'A' && c <= 'F') return static_cast<uint8_t>(c - 'A' + 10);
+  throw std::runtime_error("invalid hex");
+}
+
+static std::vector<uint8_t> hex_to_bytes(const char *hex) {
+  const size_t len = std::strlen(hex);
+  if (len % 2 != 0) throw std::runtime_error("invalid hex length");
+  std::vector<uint8_t> out(len / 2);
+  for (size_t i = 0; i < out.size(); ++i) {
+    out[i] = static_cast<uint8_t>((hex_value(hex[i * 2]) << 4) | hex_value(hex[i * 2 + 1]));
+  }
+  return out;
+}
+
+static uint32_t read_be32(const uint8_t *bytes) {
+  return (static_cast<uint32_t>(bytes[0]) << 24) |
+         (static_cast<uint32_t>(bytes[1]) << 16) |
+         (static_cast<uint32_t>(bytes[2]) << 8) |
+         static_cast<uint32_t>(bytes[3]);
+}
+
+static int host_base58_value(char c) {
+  const char *alphabet = "123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz";
+  for (int i = 0; i < 58; ++i) {
+    if (alphabet[i] == c) return i;
+  }
+  return -1;
+}
+
+static bool big25_mul_small(uint8_t value[25], uint32_t multiplier) {
+  uint32_t carry = 0;
+  for (int i = 24; i >= 0; --i) {
+    uint32_t product = static_cast<uint32_t>(value[i]) * multiplier + carry;
+    value[i] = static_cast<uint8_t>(product & 0xff);
+    carry = product >> 8;
+  }
+  return carry == 0;
+}
+
+static bool big25_add_small(uint8_t value[25], uint32_t addend) {
+  uint32_t carry = addend;
+  for (int i = 24; i >= 0 && carry > 0; --i) {
+    uint32_t sum = static_cast<uint32_t>(value[i]) + (carry & 0xff);
+    value[i] = static_cast<uint8_t>(sum & 0xff);
+    carry = (carry >> 8) + (sum >> 8);
+  }
+  return carry == 0;
+}
+
+static bool big25_sub_one(uint8_t value[25]) {
+  for (int i = 24; i >= 0; --i) {
+    if (value[i] > 0) {
+      --value[i];
+      return true;
+    }
+    value[i] = 0xff;
+  }
+  return false;
+}
+
+static uint64_t payload21_word(const uint8_t value[21], int word_index) {
+  uint64_t out = 0;
+  const int offset = word_index * 8;
+  const int limit = word_index == 2 ? 5 : 8;
+  for (int i = 0; i < limit; ++i) {
+    out |= static_cast<uint64_t>(value[offset + i]) << (56 - 8 * i);
+  }
+  return out;
+}
+
+static TronPrefixRange make_prefix_range(char prefix_after_t) {
+  TronPrefixRange range{};
+  const int first = host_base58_value('T');
+  const int second = host_base58_value(prefix_after_t);
+  if (first < 0 || second < 0) throw std::runtime_error("invalid Base58 prefix");
+
+  uint32_t prefix_value = static_cast<uint32_t>(first) * 58U + static_cast<uint32_t>(second);
+  if (!big25_add_small(range.low, prefix_value)) throw std::runtime_error("prefix low overflow");
+  if (!big25_add_small(range.high, prefix_value + 1U)) throw std::runtime_error("prefix high overflow");
+  for (int i = 0; i < 32; ++i) {
+    if (!big25_mul_small(range.low, 58U)) throw std::runtime_error("prefix low scale overflow");
+    if (!big25_mul_small(range.high, 58U)) throw std::runtime_error("prefix high scale overflow");
+  }
+  if (!big25_sub_one(range.high)) throw std::runtime_error("prefix high underflow");
+  uint8_t possible_low21[21];
+  uint8_t possible_high21[21];
+  std::memcpy(possible_low21, range.low, sizeof(possible_low21));
+  std::memcpy(possible_high21, range.high, sizeof(possible_high21));
+  for (int i = 0; i < 3; ++i) {
+    range.possibleLowWords[i] = payload21_word(possible_low21, i);
+    range.possibleHighWords[i] = payload21_word(possible_high21, i);
+  }
+  return range;
+}
+
+static TronVectorInput make_input(const char *public_key_uncompressed_hex, const char *expected_address) {
+  TronVectorInput input{};
+  const char *public_key64_hex = public_key_uncompressed_hex;
+  if (std::strlen(public_key_uncompressed_hex) == 130 &&
+      public_key_uncompressed_hex[0] == '0' &&
+      public_key_uncompressed_hex[1] == '4') {
+    public_key64_hex = public_key_uncompressed_hex + 2;
+  }
+  std::vector<uint8_t> public_key = hex_to_bytes(public_key64_hex);
+  if (public_key.size() != 64) throw std::runtime_error("public key must be 64 bytes");
+  std::memcpy(input.public_key64, public_key.data(), 64);
+  uint32_t *x32 = reinterpret_cast<uint32_t *>(input.x);
+  uint32_t *y32 = reinterpret_cast<uint32_t *>(input.y);
+  for (int i = 0; i < 8; ++i) {
+    x32[7 - i] = read_be32(public_key.data() + i * 4);
+    y32[7 - i] = read_be32(public_key.data() + 32 + i * 4);
+  }
+  if (std::strlen(expected_address) >= sizeof(input.expected_address)) {
+    throw std::runtime_error("expected address too long");
+  }
+  std::strncpy(input.expected_address, expected_address, sizeof(input.expected_address) - 1);
+  const size_t address_len = std::strlen(expected_address);
+  if (address_len < 6 || expected_address[0] != 'T') {
+    throw std::runtime_error("expected address must be a TRON Base58 address");
+  }
+  std::memcpy(input.suffix5, expected_address + address_len - 5, 5);
+  input.suffix5[5] = 0;
+  std::memcpy(input.wrong_suffix5, input.suffix5, 6);
+  input.wrong_suffix5[0] = input.wrong_suffix5[0] == '1' ? '2' : '1';
+  return input;
+}
+
+static const char *cuda_status(cudaError_t status) {
+  return cudaGetErrorString(status);
+}
+
+int main() {
+  std::vector<TronVectorInput> inputs;
+  inputs.push_back(make_input(
+      "0479be667ef9dcbbac55a06295ce870b07029bfcdb2dce28d959f2815b16f81798483ada7726a3c4655da4fbfc0e1108a8fd17b448a68554199c47d08ffb10d4b8",
+      "TMVQGm1qAQYVdetCeGRRkTWYYrLXuHK2HC"));
+  inputs.push_back(make_input(
+      "04c6047f9441ed7d6d3045406e95c07cd85c778e4b8cef3ca7abac09b95c709ee51ae168fea63dc339a3c58419466ceaeef7f632653266d0e1236431a950cfe52a",
+      "TDvSsdrNM5eeXNL3czpa6AxLDHZA9nwe9K"));
+  inputs.push_back(make_input(
+      "04f9308a019258c31049344f85f89d5229b531c845836f99b08601f113bce036f9388f7b0f632de8140fe337e62a37f3566500a99934c2231b6cb9fd7584b8e672",
