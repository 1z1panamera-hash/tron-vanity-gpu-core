index 0000000..9724e60
--- /dev/null
+++ b/GPU/GPUTron.h
@@ -0,0 +1,430 @@
+/*
+ * TRON address helpers for the VanitySearch GPU adaptation prototype.
+ *
+ * This header is a correctness bridge for public test vectors first. It does
+ * not generate private keys and does not return secret material.
+ */
+
+#ifndef GPU_TRON_H
+#define GPU_TRON_H
+
+#include <stdint.h>
+#include "GPUTronTypes.h"
+
+__device__ __forceinline__ int tron_base58_value(char c) {
+  const char alphabet[] = "123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz";
+  for (int i = 0; i < 58; ++i) {
+    if (alphabet[i] == c) return i;
+  }
+  return -1;
+}
+
+__device__ __noinline__ uint64_t tron_suffix5_value(const char suffix5[6]) {
+  uint64_t value = 0;
+  for (int i = 0; i < 5; ++i) {
+    int digit = tron_base58_value(suffix5[i]);
+    if (digit < 0) return UINT64_MAX;
+    value = value * 58ULL + static_cast<uint64_t>(digit);
+  }
+  return value;
+}
+
+__device__ __noinline__ int tron_payload25_compare(
+    const uint8_t a[25],
+    const uint8_t b[25]) {
+  for (int i = 0; i < 25; ++i) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
+
+__device__ __forceinline__ int tron_payload21_words_compare(
+    const uint64_t a[3],
+    const uint64_t b[3]) {
+  for (int i = 0; i < 3; ++i) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
+
+__device__ __forceinline__ uint64_t tron_pack_payload21_word(
+    const uint8_t payload21[21],
+    int wordIndex) {
+  uint64_t value = 0;
+  const int offset = wordIndex * 8;
+  const int limit = wordIndex == 2 ? 5 : 8;
+  for (int i = 0; i < limit; ++i) {
+    value |= static_cast<uint64_t>(payload21[offset + i]) << (56 - 8 * i);
+  }
+  return value;
+}
+
+__device__ __noinline__ bool tron_payload25_matches_prefix_range(
+    const uint8_t payload25[25],
+    const TronPrefixRange prefixRange) {
+  return tron_payload25_compare(payload25, prefixRange.low) >= 0 &&
+         tron_payload25_compare(payload25, prefixRange.high) <= 0;
+}
+
+__device__ __forceinline__ bool tron_payload21_can_match_prefix_range(
+    const uint8_t payload21[21],
+    const TronPrefixRange prefixRange) {
+  uint64_t words[3];
+  words[0] = tron_pack_payload21_word(payload21, 0);
+  words[1] = tron_pack_payload21_word(payload21, 1);
+  words[2] = tron_pack_payload21_word(payload21, 2);
+  return tron_payload21_words_compare(words, prefixRange.possibleLowWords) >= 0 &&
+         tron_payload21_words_compare(words, prefixRange.possibleHighWords) <= 0;
+}
+
+__device__ __forceinline__ uint32_t tron_read_be32(const uint8_t *bytes) {
+  return (static_cast<uint32_t>(bytes[0]) << 24) |
+         (static_cast<uint32_t>(bytes[1]) << 16) |
+         (static_cast<uint32_t>(bytes[2]) << 8) |
+         static_cast<uint32_t>(bytes[3]);
+}
+
+__device__ __forceinline__ uint64_t tron_mod58p5_fast_u64(uint64_t value) {
+  const uint64_t base58_power_5 = 656356768ULL;
+  const uint64_t reciprocal_2p64 = 28104751825ULL;
+  uint64_t quotient = __umul64hi(value, reciprocal_2p64);
+  uint64_t remainder = value - quotient * base58_power_5;
+  if (remainder >= base58_power_5) remainder -= base58_power_5;
+  if (remainder >= base58_power_5) remainder -= base58_power_5;
+  return remainder;
+}
+
+__device__ __forceinline__ uint64_t tron_mod58p5_append_be32(uint64_t value, uint32_t chunk) {
+  const uint64_t base256_power_4_mod58p5 = 356826688ULL;
+  return tron_mod58p5_fast_u64(
+      (value * base256_power_4_mod58p5) + static_cast<uint64_t>(chunk));
+}
+
+__device__ __forceinline__ uint64_t tron_payload21_checksum_mod_base58_power5(
+    const uint8_t payload21[21],
+    const uint8_t checksum4[4]) {
+  uint64_t value = static_cast<uint64_t>(payload21[0]);
+  for (int offset = 1; offset < 21; offset += 4) {
+    value = tron_mod58p5_append_be32(value, tron_read_be32(payload21 + offset));
+  }
+  value = tron_mod58p5_append_be32(value, tron_read_be32(checksum4));
+  return value;
+}
+
+__device__ __forceinline__ uint64_t tron_payload21_checksum_word_mod_base58_power5(
+    const uint8_t payload21[21],
+    uint32_t checksum4_be32) {
+  uint64_t value = static_cast<uint64_t>(payload21[0]);
+  for (int offset = 1; offset < 21; offset += 4) {
+    value = tron_mod58p5_append_be32(value, tron_read_be32(payload21 + offset));
+  }
+  value = tron_mod58p5_append_be32(value, checksum4_be32);
+  return value;
+}
+
+__device__ __forceinline__ bool tron_payload21_checksum_matches_suffix5(
+    const uint8_t payload21[21],
+    const uint8_t checksum4[4],
+    uint64_t suffix5_value) {
+  return tron_payload21_checksum_mod_base58_power5(payload21, checksum4) == suffix5_value;
+}
+
+__device__ __forceinline__ bool tron_payload21_checksum_word_matches_suffix5(
+    const uint8_t payload21[21],
+    uint32_t checksum4_be32,
+    uint64_t suffix5_value) {
+  return tron_payload21_checksum_word_mod_base58_power5(payload21, checksum4_be32) ==
+         suffix5_value;
+}
+
+__device__ __noinline__ uint64_t tron_payload25_mod_base58_power(
+    const uint8_t payload25[25],
+    uint64_t modulus) {
+  uint64_t value = 0;
+  for (int i = 0; i < 25; ++i) {
+    value = ((value * 256ULL) + static_cast<uint64_t>(payload25[i])) % modulus;
+  }
+  return value;
+}
+
+__device__ __noinline__ bool tron_payload25_matches_suffix5(
+    const uint8_t payload25[25],
+    uint64_t suffix5_value) {
+  const uint64_t base58_power_5 = 656356768ULL;
+  return tron_payload25_mod_base58_power(payload25, base58_power_5) == suffix5_value;
+}
+
+__device__ __forceinline__ uint64_t tron_rotl64(uint64_t value, int shift) {
+  shift &= 63;
+  return (value << shift) | (value >> ((64 - shift) & 63));
+}
+
+__device__ __noinline__ void tron_keccak_f1600(uint64_t state[25]) {
+  const int rho[25] = {
+     0, 36,  3, 41, 18,
+     1, 44, 10, 45,  2,
+    62,  6, 43, 15, 61,
+    28, 55, 25, 21, 56,
+    27, 20, 39,  8, 14,
+  };
+  const uint64_t rc[24] = {
+    0x0000000000000001ULL, 0x0000000000008082ULL,
+    0x800000000000808aULL, 0x8000000080008000ULL,
+    0x000000000000808bULL, 0x0000000080000001ULL,
+    0x8000000080008081ULL, 0x8000000000008009ULL,
+    0x000000000000008aULL, 0x0000000000000088ULL,
+    0x0000000080008009ULL, 0x000000008000000aULL,
+    0x000000008000808bULL, 0x800000000000008bULL,
+    0x8000000000008089ULL, 0x8000000000008003ULL,
+    0x8000000000008002ULL, 0x8000000000000080ULL,
+    0x000000000000800aULL, 0x800000008000000aULL,
+    0x8000000080008081ULL, 0x8000000000008080ULL,
+    0x0000000080000001ULL, 0x8000000080008008ULL,
+  };
+
+  for (int round = 0; round < 24; ++round) {
+    uint64_t c[5];
+    uint64_t d[5];
+    uint64_t b[25];
+    for (int x = 0; x < 5; ++x) {
+      c[x] = state[x] ^ state[x + 5] ^ state[x + 10] ^ state[x + 15] ^ state[x + 20];
+    }
+    for (int x = 0; x < 5; ++x) {
+      d[x] = c[(x + 4) % 5] ^ tron_rotl64(c[(x + 1) % 5], 1);
+    }
+    for (int x = 0; x < 5; ++x) {
+      for (int y = 0; y < 5; ++y) {
+        state[x + 5 * y] ^= d[x];
+      }
+    }
+    for (int i = 0; i < 25; ++i) {
+      b[i] = 0;
+    }
+    for (int x = 0; x < 5; ++x) {
+      for (int y = 0; y < 5; ++y) {
+        b[y + 5 * ((2 * x + 3 * y) % 5)] =
+            tron_rotl64(state[x + 5 * y], rho[x * 5 + y]);
+      }
+    }
+    for (int x = 0; x < 5; ++x) {
+      for (int y = 0; y < 5; ++y) {
+        state[x + 5 * y] =
+            b[x + 5 * y] ^
+            ((~b[((x + 1) % 5) + 5 * y]) & b[((x + 2) % 5) + 5 * y]);
+      }
+    }
+    state[0] ^= rc[round];
+  }
+}
+
+__device__ __noinline__ void tron_keccak256_64(const uint8_t input64[64], uint8_t digest32[32]) {
+  uint64_t state[25];
+  uint8_t block[136];
+  for (int i = 0; i < 25; ++i) state[i] = 0;
+  for (int i = 0; i < 136; ++i) block[i] = 0;
+  for (int i = 0; i < 64; ++i) block[i] = input64[i];
+  block[64] = 0x01;
+  block[135] |= 0x80;
+
+  for (int lane = 0; lane < 17; ++lane) {
+    uint64_t value = 0;
+    for (int b = 0; b < 8; ++b) {
+      value |= static_cast<uint64_t>(block[lane * 8 + b]) << (8 * b);
+    }
+    state[lane] ^= value;
+  }
+
+  tron_keccak_f1600(state);
+
+  int pos = 0;
+  for (int lane = 0; lane < 17 && pos < 32; ++lane) {
+    for (int b = 0; b < 8 && pos < 32; ++b) {
+      digest32[pos++] = static_cast<uint8_t>((state[lane] >> (8 * b)) & 0xff);
+    }
+  }
+}
+
+__device__ __forceinline__ uint32_t tron_bswap32(uint32_t value) {
+  return ((value & 0xff000000U) >> 24) |
+         ((value & 0x00ff0000U) >> 8) |
+         ((value & 0x0000ff00U) << 8) |
+         ((value & 0x000000ffU) << 24);
+}
+
+__device__ __noinline__ void tron_payload21_from_xy(
+    const uint64_t *x,
+    const uint64_t *y,
+    uint8_t payload21[21]) {
+  uint64_t state[25];
+  for (int i = 0; i < 25; ++i) state[i] = 0;
+
+  const uint32_t *x32 = reinterpret_cast<const uint32_t *>(x);
+  const uint32_t *y32 = reinterpret_cast<const uint32_t *>(y);
+  for (int lane = 0; lane < 4; ++lane) {
+    const int hi = 7 - lane * 2;
+    const int lo = hi - 1;
+    state[lane] =
+        static_cast<uint64_t>(tron_bswap32(x32[hi])) |
+        (static_cast<uint64_t>(tron_bswap32(x32[lo])) << 32);
+    state[4 + lane] =
+        static_cast<uint64_t>(tron_bswap32(y32[hi])) |
+        (static_cast<uint64_t>(tron_bswap32(y32[lo])) << 32);
+  }
+
+  state[8] = 0x01ULL;
+  state[16] = 0x8000000000000000ULL;
+  tron_keccak_f1600(state);
+
+  payload21[0] = 0x41;
+  for (int i = 0; i < 20; ++i) {
+    const int pos = 12 + i;
+    payload21[i + 1] = static_cast<uint8_t>((state[pos >> 3] >> (8 * (pos & 7))) & 0xff);
+  }
+}
+
+__device__ __noinline__ uint32_t tron_checksum4_be32(const uint8_t payload21[21]) {
+  uint32_t s[8];
+  uint32_t w[16];
+
+  w[0] = tron_read_be32(payload21);
+  w[1] = tron_read_be32(payload21 + 4);
+  w[2] = tron_read_be32(payload21 + 8);
+  w[3] = tron_read_be32(payload21 + 12);
+  w[4] = tron_read_be32(payload21 + 16);
+  w[5] = (static_cast<uint32_t>(payload21[20]) << 24) | 0x00800000U;
+  w[6] = 0;
+  w[7] = 0;
+  w[8] = 0;
+  w[9] = 0;
+  w[10] = 0;
+  w[11] = 0;
+  w[12] = 0;
+  w[13] = 0;
+  w[14] = 0;
+  w[15] = 168U;
+
+  SHA256Initialize(s);
+  SHA256Transform(s, w);
+
+  for (int i = 0; i < 8; ++i) w[i] = s[i];
+  w[8] = 0x80000000U;
+  w[9] = 0;
+  w[10] = 0;
+  w[11] = 0;
+  w[12] = 0;
+  w[13] = 0;
+  w[14] = 0;
+  w[15] = 256U;
+
+  SHA256Initialize(s);
+  SHA256Transform(s, w);
+  return s[0];
+}
+
+__device__ __noinline__ bool tron_payload21_checksum_fused_matches_suffix5(
+    const uint8_t payload21[21],
+    uint64_t suffix5_value) {
+  uint32_t s[8];
+  uint32_t w[16];
+
+  const uint32_t w0 = tron_read_be32(payload21);
+  const uint32_t w1 = tron_read_be32(payload21 + 4);
+  const uint32_t w2 = tron_read_be32(payload21 + 8);
+  const uint32_t w3 = tron_read_be32(payload21 + 12);
+  const uint32_t w4 = tron_read_be32(payload21 + 16);
+  const uint32_t w5 = (static_cast<uint32_t>(payload21[20]) << 24) | 0x00800000U;
+
+  w[0] = w0;
+  w[1] = w1;
+  w[2] = w2;
+  w[3] = w3;
+  w[4] = w4;
+  w[5] = w5;
+  w[6] = 0;
+  w[7] = 0;
+  w[8] = 0;
+  w[9] = 0;
+  w[10] = 0;
+  w[11] = 0;
+  w[12] = 0;
+  w[13] = 0;
+  w[14] = 0;
+  w[15] = 168U;
+
+  SHA256Initialize(s);
+  SHA256Transform(s, w);
+
+  for (int i = 0; i < 8; ++i) w[i] = s[i];
+  w[8] = 0x80000000U;
+  w[9] = 0;
+  w[10] = 0;
+  w[11] = 0;
+  w[12] = 0;
+  w[13] = 0;
+  w[14] = 0;
+  w[15] = 256U;
+
+  SHA256Initialize(s);
+  SHA256Transform(s, w);
+
+  uint64_t value = 0x41ULL;
+  value = tron_mod58p5_append_be32(value, ((w0 & 0x00ffffffU) << 8) | (w1 >> 24));
+  value = tron_mod58p5_append_be32(value, ((w1 & 0x00ffffffU) << 8) | (w2 >> 24));
+  value = tron_mod58p5_append_be32(value, ((w2 & 0x00ffffffU) << 8) | (w3 >> 24));
+  value = tron_mod58p5_append_be32(value, ((w3 & 0x00ffffffU) << 8) | (w4 >> 24));
+  value = tron_mod58p5_append_be32(value, ((w4 & 0x00ffffffU) << 8) | (w5 >> 24));
+  value = tron_mod58p5_append_be32(value, s[0]);
+  return value == suffix5_value;
+}
+
+__device__ __noinline__ void tron_checksum4(const uint8_t payload21[21], uint8_t checksum4[4]) {
+  uint32_t checksum = tron_checksum4_be32(payload21);
+  checksum4[0] = static_cast<uint8_t>((checksum >> 24) & 0xff);
+  checksum4[1] = static_cast<uint8_t>((checksum >> 16) & 0xff);
+  checksum4[2] = static_cast<uint8_t>((checksum >> 8) & 0xff);
+  checksum4[3] = static_cast<uint8_t>(checksum & 0xff);
+}
+
+__device__ __noinline__ int tron_base58_payload25(const uint8_t payload25[25], char out[48]) {
+  const char alphabet[] = "123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz";
+  uint8_t digits[64];
+  int ret_pos = 0;
+  int first = 0;
+  while (first < 25 && payload25[first] == 0) {
+    out[ret_pos++] = '1';
+    ++first;
+  }
+  int digits_len = 1;
+  digits[0] = 0;
+  for (int i = first; i < 25; ++i) {
+    uint32_t carry = payload25[i];
+    for (int j = 0; j < digits_len; ++j) {
+      carry += static_cast<uint32_t>(digits[j]) << 8;
+      digits[j] = static_cast<uint8_t>(carry % 58);
+      carry /= 58;
+    }
+    while (carry > 0) {
+      digits[digits_len++] = static_cast<uint8_t>(carry % 58);
+      carry /= 58;
+    }
+  }
+  for (int i = 0; i < digits_len; ++i) {
+    out[ret_pos++] = alphabet[digits[digits_len - 1 - i]];
+  }
+  out[ret_pos] = 0;
+  return ret_pos;
+}
+
+__device__ __noinline__ void tron_payload21_from_public_key64(
+    const uint8_t public_key64[64],
+    uint8_t payload21[21]) {
+  uint8_t digest[32];
+  tron_keccak256_64(public_key64, digest);
+  payload21[0] = 0x41;
+  for (int i = 0; i < 20; ++i) payload21[i + 1] = digest[i + 12];
+}
+
+__device__ __noinline__ void tron_payload25_from_payload21(
+    const uint8_t payload21[21],
+    uint8_t payload25[25]) {
+  uint8_t checksum[4];
+  for (int i = 0; i < 21; ++i) payload25[i] = payload21[i];
+  tron_checksum4(payload21, checksum);
+  for (int i = 0; i < 4; ++i) payload25[21 + i] = checksum[i];
+}
+
+__device__ __noinline__ void tron_payload25_from_public_key64(
+    const uint8_t public_key64[64],
+    uint8_t payload25[25]) {
+  uint8_t payload21[21];
+  tron_payload21_from_public_key64(public_key64, payload21);
+  tron_payload25_from_payload21(payload21, payload25);
+}
+
+__device__ __noinline__ int tron_address_from_public_key64(
+    const uint8_t public_key64[64],
+    char address[48],
+    uint8_t payload25[25]) {
+  tron_payload25_from_public_key64(public_key64, payload25);
+  return tron_base58_payload25(payload25, address);
+}
+
+__device__ __noinline__ void tron_public_key64_from_xy(
+    uint64_t *x,
+    uint64_t *y,
+    uint8_t public_key64[64]) {
+  uint32_t *x32 = (uint32_t *)(x);
+  uint32_t *y32 = (uint32_t *)(y);
+  for (int i = 0; i < 8; ++i) {
+    uint32_t xw = x32[7 - i];
+    uint32_t yw = y32[7 - i];
+    public_key64[i * 4] = static_cast<uint8_t>((xw >> 24) & 0xff);
+    public_key64[i * 4 + 1] = static_cast<uint8_t>((xw >> 16) & 0xff);
+    public_key64[i * 4 + 2] = static_cast<uint8_t>((xw >> 8) & 0xff);
+    public_key64[i * 4 + 3] = static_cast<uint8_t>(xw & 0xff);
+    public_key64[32 + i * 4] = static_cast<uint8_t>((yw >> 24) & 0xff);
+    public_key64[32 + i * 4 + 1] = static_cast<uint8_t>((yw >> 16) & 0xff);
+    public_key64[32 + i * 4 + 2] = static_cast<uint8_t>((yw >> 8) & 0xff);
+    public_key64[32 + i * 4 + 3] = static_cast<uint8_t>(yw & 0xff);
+  }
+}
+
+__device__ __noinline__ bool tron_match_suffix5(
+    const char address[48],
+    int address_len,
+    const char suffix5[6]) {
+  if (address_len < 6) return false;
+  if (address[0] != 'T') return false;
+  for (int i = 0; i < 5; ++i) {
+    if (address[address_len - 5 + i] != suffix5[i]) return false;
+  }
+  return true;
+}
+
+#endif
