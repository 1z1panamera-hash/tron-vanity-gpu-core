+    Load256(px, sx);
+    Load256(py, sy);
+    ModNeg256(dy, Gy[i]);
+    ModSub256(dy, py);
+
+    _ModMult(_s, dy, dx[i]);
+    _ModSqr(_p2,_s);
+
+    ModSub256(px, _p2, px);
+    ModSub256(px, Gx[i]);
+
+    ModSub256(py, px, Gx[i]);
+    _ModMult(py, _s);
+    ModSub256(py, Gy[i], py);
+
+    CHECK_TRON_PATTERN(0);
+
+    i++;
+
+    __syncthreads();
+    Load256(px, sx);
+    Load256(py, sy);
+    ModSub256(dy, _2Gny, py);
+
