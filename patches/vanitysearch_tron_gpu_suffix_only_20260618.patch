--- /dev/null
+++ b/scripts/runpod_tron_gpu_pattern_benchmark.sh
@@ -0,0 +1,102 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if [ "${ALLOW_RUNPOD_TRON_GPU_PATTERN_BENCHMARK:-0}" != "1" ]; then
+  echo "refusing_to_run_without_ALLOW_RUNPOD_TRON_GPU_PATTERN_BENCHMARK=1" >&2
+  echo "This bounded benchmark is intended for a short-lived CUDA RunPod Pod only." >&2
+  exit 2
+fi
+
+CUDA_HOME="${CUDA_HOME:-/usr/local/cuda}"
+CUDA_ARCH="${CUDA_ARCH:-80}"
+CXXCUDA="${CXXCUDA:-/usr/bin/g++}"
+BENCHMARK_PATTERN="${BENCHMARK_PATTERN:-T*CDEFG}"
+BENCHMARK_SECONDS="${BENCHMARK_SECONDS:-10}"
+GPU_GRID="${GPU_GRID:-8,128}"
+
+case "$BENCHMARK_SECONDS" in
+  ''|*[!0-9]*)
+    echo "BENCHMARK_SECONDS must be an integer" >&2
+    exit 1
+    ;;
+esac
+if [ "$BENCHMARK_SECONDS" -lt 3 ] || [ "$BENCHMARK_SECONDS" -gt 30 ]; then
+  echo "BENCHMARK_SECONDS must be between 3 and 30 for this bounded check" >&2
+  exit 1
+fi
+
+echo "== build VanitySearch with GPU support"
+make gpu=1 CCAP="$CUDA_ARCH" CUDA="$CUDA_HOME" CXXCUDA="$CXXCUDA" all
+
+echo "== run bounded TRON GPU pattern benchmark"
+cmd=(env TRON_SUPPRESS_SECRET_OUTPUT=1 timeout "$BENCHMARK_SECONDS"s ./VanitySearch -gpu -t 0 -g "$GPU_GRID" "$BENCHMARK_PATTERN")
+set +e
+if command -v script >/dev/null 2>&1; then
+  printf -v shell_cmd "%q " "${cmd[@]}"
+  script -q -e -c "$shell_cmd" /tmp/tron_gpu_pattern_benchmark_stdout.txt \
+    >/dev/null 2> /tmp/tron_gpu_pattern_benchmark_stderr.txt
+else
+  "${cmd[@]}" \
+    > /tmp/tron_gpu_pattern_benchmark_stdout.txt \
+    2> /tmp/tron_gpu_pattern_benchmark_stderr.txt
+fi
+rc=$?
+set -e
+
+if [ "$rc" -ne 0 ] && [ "$rc" -ne 124 ]; then
+  echo "tron_gpu_pattern_benchmark_failed rc=$rc" >&2
+  tail -80 /tmp/tron_gpu_pattern_benchmark_stdout.txt >&2 || true
+  tail -80 /tmp/tron_gpu_pattern_benchmark_stderr.txt >&2 || true
+  exit 1
+fi
+
+if grep -Eiq "Priv|WIF|HEX|private_key|mnemonic|seed|token|secret" \
+  /tmp/tron_gpu_pattern_benchmark_stdout.txt /tmp/tron_gpu_pattern_benchmark_stderr.txt; then
+  echo "unexpected sensitive marker or hit output in TRON GPU pattern benchmark" >&2
+  exit 1
+fi
+
+python3 - "$BENCHMARK_PATTERN" "$BENCHMARK_SECONDS" "$GPU_GRID" "$rc" <<'PY'
+from pathlib import Path
+import json
+import re
+import sys
+
+pattern, seconds, grid, rc = sys.argv[1], int(sys.argv[2]), sys.argv[3], int(sys.argv[4])
+stdout = Path("/tmp/tron_gpu_pattern_benchmark_stdout.txt").read_text(errors="ignore")
+stderr = Path("/tmp/tron_gpu_pattern_benchmark_stderr.txt").read_text(errors="ignore")
+matches = re.findall(r"\[([0-9.]+) Mkey/s\]\[GPU ([0-9.]+) Mkey/s\]", stdout)
+if not matches:
+    print(json.dumps({
+        "mode": "tron_gpu_pattern_benchmark",
+        "passed": False,
+        "error": "no Mkey/s sample found",
+        "return_code": rc,
+        "stderr_tail": stderr[-2000:],
+    }, indent=2, sort_keys=True))
+    raise SystemExit(1)
+
+total_mkey_s, gpu_mkey_s = (float(x) for x in matches[-1])
+result = {
+    "mode": "tron_gpu_pattern_benchmark",
+    "passed": True,
