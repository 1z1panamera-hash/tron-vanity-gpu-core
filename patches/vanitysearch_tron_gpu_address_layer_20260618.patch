+};
+
+__global__ void tron_vector_kernel(
+    const TronVectorInput *inputs,
+    TronVectorResult *results,
+    int count) {
+  int idx = blockIdx.x * blockDim.x + threadIdx.x;
+  if (idx >= count) return;
+
+  TronVectorResult result{};
+  result.address_len =
+      tron_address_from_public_key64(inputs[idx].public_key64, result.computed_address, result.payload25);
+  result.passed = 1;
+  for (int i = 0; i < 48; ++i) {
+    if (result.computed_address[i] != inputs[idx].expected_address[i]) {
+      result.passed = 0;
+      break;
+    }
+    if (inputs[idx].expected_address[i] == 0) break;
+  }
+  results[idx] = result;
+}
+
+static uint8_t hex_value(char c) {
+  if (c >= '0' && c <= '9') return static_cast<uint8_t>(c - '0');
+  if (c >= 'a' && c <= 'f') return static_cast<uint8_t>(c - 'a' + 10);
+  if (c >= 'A' && c <= 'F') return static_cast<uint8_t>(c - 'A' + 10);
+  throw std::runtime_error("invalid hex");
+}
+
+static std::vector<uint8_t> hex_to_bytes(const char *hex) {
+  const size_t len = std::strlen(hex);
+  if (len % 2 != 0) throw std::runtime_error("invalid hex length");
+  std::vector<uint8_t> out(len / 2);
+  for (size_t i = 0; i < out.size(); ++i) {
+    out[i] = static_cast<uint8_t>((hex_value(hex[i * 2]) << 4) | hex_value(hex[i * 2 + 1]));
+  }
+  return out;
+}
+
+static TronVectorInput make_input(const char *public_key_uncompressed_hex, const char *expected_address) {
+  TronVectorInput input{};
+  const char *public_key64_hex = public_key_uncompressed_hex;
+  if (std::strlen(public_key_uncompressed_hex) == 130 &&
+      public_key_uncompressed_hex[0] == '0' &&
+      public_key_uncompressed_hex[1] == '4') {
+    public_key64_hex = public_key_uncompressed_hex + 2;
+  }
+  std::vector<uint8_t> public_key = hex_to_bytes(public_key64_hex);
+  if (public_key.size() != 64) throw std::runtime_error("public key must be 64 bytes");
+  std::memcpy(input.public_key64, public_key.data(), 64);
+  if (std::strlen(expected_address) >= sizeof(input.expected_address)) {
+    throw std::runtime_error("expected address too long");
+  }
+  std::strncpy(input.expected_address, expected_address, sizeof(input.expected_address) - 1);
+  return input;
+}
+
+static const char *cuda_status(cudaError_t status) {
+  return cudaGetErrorString(status);
+}
+
+int main() {
+  std::vector<TronVectorInput> inputs;
+  inputs.push_back(make_input(
+      "0479be667ef9dcbbac55a06295ce870b07029bfcdb2dce28d959f2815b16f81798483ada7726a3c4655da4fbfc0e1108a8fd17b448a68554199c47d08ffb10d4b8",
+      "TMVQGm1qAQYVdetCeGRRkTWYYrLXuHK2HC"));
+  inputs.push_back(make_input(
+      "04c6047f9441ed7d6d3045406e95c07cd85c778e4b8cef3ca7abac09b95c709ee51ae168fea63dc339a3c58419466ceaeef7f632653266d0e1236431a950cfe52a",
+      "TDvSsdrNM5eeXNL3czpa6AxLDHZA9nwe9K"));
+  inputs.push_back(make_input(
+      "04f9308a019258c31049344f85f89d5229b531c845836f99b08601f113bce036f9388f7b0f632de8140fe337e62a37f3566500a99934c2231b6cb9fd7584b8e672",
+      "TKTX96CBxr5kvhjsDHcqoiPWZageGxoTW3"));
+  inputs.push_back(make_input(
+      "0437a4aef1f8423ca076e4b7d99a8cabff40ddb8231f2a9f01081f15d7fa65c1bab96ced90a1b8f9b43a18fc900ff55af2be0e94b90a434fca5b9e226b835024cd",
+      "TUqoWCpNbTPc7EwG2GbLpyPr7TYzEVYjhb"));
+
+  TronVectorInput *d_inputs = nullptr;
+  TronVectorResult *d_results = nullptr;
+  std::vector<TronVectorResult> results(inputs.size());
+
+  cudaError_t status = cudaMalloc(&d_inputs, inputs.size() * sizeof(TronVectorInput));
+  if (status != cudaSuccess) {
+    std::fprintf(stderr, "cudaMalloc inputs failed: %s\n", cuda_status(status));
+    return 1;
+  }
+  status = cudaMalloc(&d_results, inputs.size() * sizeof(TronVectorResult));
+  if (status != cudaSuccess) {
+    std::fprintf(stderr, "cudaMalloc results failed: %s\n", cuda_status(status));
+    cudaFree(d_inputs);
+    return 1;
+  }
+  status = cudaMemcpy(
+      d_inputs,
+      inputs.data(),
+      inputs.size() * sizeof(TronVectorInput),
+      cudaMemcpyHostToDevice);
+  if (status != cudaSuccess) {
+    std::fprintf(stderr, "cudaMemcpy inputs failed: %s\n", cuda_status(status));
+    cudaFree(d_inputs);
+    cudaFree(d_results);
+    return 1;
+  }
+
+  tron_vector_kernel<<<1, 32>>>(d_inputs, d_results, static_cast<int>(inputs.size()));
+  status = cudaDeviceSynchronize();
+  if (status != cudaSuccess) {
+    std::fprintf(stderr, "tron_vector_kernel failed: %s\n", cuda_status(status));
+    cudaFree(d_inputs);
+    cudaFree(d_results);
+    return 1;
+  }
+
+  status = cudaMemcpy(
+      results.data(),
+      d_results,
+      results.size() * sizeof(TronVectorResult),
+      cudaMemcpyDeviceToHost);
+  cudaFree(d_inputs);
+  cudaFree(d_results);
+  if (status != cudaSuccess) {
+    std::fprintf(stderr, "cudaMemcpy results failed: %s\n", cuda_status(status));
+    return 1;
+  }
+
+  int passed = 0;
+  std::printf("{\n");
+  std::printf("  \"mode\": \"tron_gpu_address_layer_vectors\",\n");
+  std::printf("  \"total_vectors\": %zu,\n", results.size());
+  std::printf("  \"results\": [\n");
+  for (size_t i = 0; i < results.size(); ++i) {
+    if (results[i].passed) ++passed;
+    std::printf(
+        "    {\"index\": %zu, \"passed\": %s, \"computed_address\": \"%s\"}%s\n",
+        i,
+        results[i].passed ? "true" : "false",
+        results[i].computed_address,
+        i + 1 == results.size() ? "" : ",");
+  }
+  std::printf("  ],\n");
+  std::printf("  \"passed\": %d,\n", passed);
+  std::printf("  \"failed\": %zu,\n", results.size() - static_cast<size_t>(passed));
+  std::printf("  \"notes\": [\n");
+  std::printf("    \"GPU TRON address layer vector check only; no search or benchmark is run.\",\n");
+  std::printf("    \"Inputs are public TEST_ONLY public-key vectors; no scalar material is generated or printed.\"\n");
+  std::printf("  ]\n");
+  std::printf("}\n");
+
+  if (passed == static_cast<int>(results.size())) {
+    std::printf("tron_gpu_address_layer_passed\n");
+    return 0;
+  }
+  return 1;
+}
