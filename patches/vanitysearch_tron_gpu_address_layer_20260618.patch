diff --git a/hash/keccak256.cpp b/hash/keccak256.cpp
new file mode 100644
index 0000000..17dd6cd
--- /dev/null
+++ b/hash/keccak256.cpp
@@ -0,0 +1,94 @@
+#include "keccak256.h"
+
+#include <string.h>
+
+static inline uint64_t rotl64(uint64_t value, int shift) {
+  shift &= 63;
+  return (value << shift) | (value >> ((64 - shift) & 63));
+}
+
+static void keccak_f1600(uint64_t state[25]) {
+  static const int rho[5][5] = {
+    {0, 36, 3, 41, 18},
+    {1, 44, 10, 45, 2},
+    {62, 6, 43, 15, 61},
+    {28, 55, 25, 21, 56},
+    {27, 20, 39, 8, 14},
+  };
+  static const uint64_t rc[24] = {
+    0x0000000000000001ULL, 0x0000000000008082ULL,
+    0x800000000000808aULL, 0x8000000080008000ULL,
+    0x000000000000808bULL, 0x0000000080000001ULL,
+    0x8000000080008081ULL, 0x8000000000008009ULL,
+    0x000000000000008aULL, 0x0000000000000088ULL,
+    0x0000000080008009ULL, 0x000000008000000aULL,
+    0x000000008000808bULL, 0x800000000000008bULL,
+    0x8000000000008089ULL, 0x8000000000008003ULL,
+    0x8000000000008002ULL, 0x8000000000000080ULL,
+    0x000000000000800aULL, 0x800000008000000aULL,
+    0x8000000080008081ULL, 0x8000000000008080ULL,
+    0x0000000080000001ULL, 0x8000000080008008ULL,
+  };
+
+  for (int round = 0; round < 24; ++round) {
+    uint64_t c[5];
+    uint64_t d[5];
+    for (int x = 0; x < 5; ++x) {
+      c[x] = state[x] ^ state[x + 5] ^ state[x + 10] ^ state[x + 15] ^ state[x + 20];
+    }
+    for (int x = 0; x < 5; ++x) {
+      d[x] = c[(x + 4) % 5] ^ rotl64(c[(x + 1) % 5], 1);
+    }
+    for (int x = 0; x < 5; ++x) {
+      for (int y = 0; y < 5; ++y) {
+        state[x + 5 * y] ^= d[x];
+      }
+    }
+
+    uint64_t b[25];
+    memset(b, 0, sizeof(b));
+    for (int x = 0; x < 5; ++x) {
+      for (int y = 0; y < 5; ++y) {
+        b[y + 5 * ((2 * x + 3 * y) % 5)] = rotl64(state[x + 5 * y], rho[x][y]);
+      }
+    }
+
+    for (int x = 0; x < 5; ++x) {
+      for (int y = 0; y < 5; ++y) {
+        state[x + 5 * y] =
+          b[x + 5 * y] ^ ((~b[((x + 1) % 5) + 5 * y]) & b[((x + 2) % 5) + 5 * y]);
+      }
+    }
+    state[0] ^= rc[round];
+  }
+}
+
+void keccak256(uint8_t *input, int length, uint8_t *digest) {
+  uint64_t state[25];
+  uint8_t block[136];
+
+  memset(state, 0, sizeof(state));
+  memset(block, 0, sizeof(block));
+  if (length < 0) length = 0;
+  if (length > 135) length = 135;
+  memcpy(block, input, length);
+  block[length] = 0x01;
+  block[135] |= 0x80;
+
+  for (int lane = 0; lane < 17; ++lane) {
+    uint64_t value = 0;
+    for (int b = 0; b < 8; ++b) {
+      value |= (uint64_t)block[lane * 8 + b] << (8 * b);
+    }
+    state[lane] ^= value;
+  }
+
+  keccak_f1600(state);
+
+  int pos = 0;
+  for (int lane = 0; lane < 17 && pos < 32; ++lane) {
+    for (int b = 0; b < 8 && pos < 32; ++b) {
+      digest[pos++] = (uint8_t)((state[lane] >> (8 * b)) & 0xff);
+    }
+  }
+}
