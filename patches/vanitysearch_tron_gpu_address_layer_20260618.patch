@@ -0,0 +1,43 @@
+# RunPod TRON GPU Address Layer Check
+
+## Purpose
+
+This is a short CUDA correctness check for the VanitySearch TRON adaptation.
+
+It verifies:
+
+- Keccak-256 over uncompressed secp256k1 public key bytes without the `04` prefix
+- TRON payload construction with leading `0x41`
+- double-SHA256 checksum
+- Base58Check address encoding
+- four public TEST_ONLY public-key vectors
+
+It does not:
+
+- generate scalar material
+- search vanity addresses
+- benchmark speed
+- call RunPod APIs
+- touch `47.80.70.211`
+
+## RunPod Command
+
+From the VanitySearch candidate repository on a CUDA-capable RunPod Pod:
+
+```bash
+CUDA_ARCH=sm_80 scripts/runpod_verify_tron_gpu_address_layer.sh
+```
+
+Use the correct `CUDA_ARCH` for the selected GPU if needed.
+
+Expected success marker:
+
+```text
+tron_gpu_address_layer_script_passed
+```
+
+## Next Gate
+
+Only after this check passes should the TRON address layer be wired into the existing VanitySearch GPU point-walking search loop.
+
+Do not treat this check as an address generation speed result.
diff --git a/scripts/runpod_verify_tron_gpu_address_layer.sh b/scripts/runpod_verify_tron_gpu_address_layer.sh
new file mode 100755
index 0000000..a6aeff3
--- /dev/null
+++ b/scripts/runpod_verify_tron_gpu_address_layer.sh
@@ -0,0 +1,34 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+cd "$ROOT"
+
+NVCC_BIN="${NVCC:-nvcc}"
+CUDA_ARCH="${CUDA_ARCH:-sm_80}"
+OUT="${OUT:-/tmp/tron_gpu_address_layer_check}"
+
+echo "== compile TRON GPU address layer vector check"
+"$NVCC_BIN" \
+  -std=c++17 \
+  -O2 \
+  -I. \
+  -I./GPU \
+  -arch="$CUDA_ARCH" \
+  GPU/GPUTronVectorCheck.cu \
+  -o "$OUT"
+
+echo "== run TRON GPU address layer vector check"
+"$OUT" | tee /tmp/tron_gpu_address_layer_check.json
+
+if ! grep -q "tron_gpu_address_layer_passed" /tmp/tron_gpu_address_layer_check.json; then
+  echo "tron_gpu_address_layer_failed" >&2
+  exit 1
+fi
+
+if grep -Eiq "private_key|mnemonic|seed|token|secret|wif|priv" /tmp/tron_gpu_address_layer_check.json; then
+  echo "unexpected sensitive marker in GPU address layer output" >&2
+  exit 1
+fi
+
+echo "tron_gpu_address_layer_script_passed"
-- 
