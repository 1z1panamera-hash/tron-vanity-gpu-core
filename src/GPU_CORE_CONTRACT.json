{
  "project": "vanity-address-api",
  "component": "tron-gpu-core",
  "default_rule": {
    "address_format": "TRON full Base58Check address",
    "product_prefix_after_t_len": 0,
    "product_suffix_len": 5,
    "internal_full_address_prefix_len": 0,
    "internal_suffix_len": 5,
    "fixed_leading_char": "T",
    "effective_random_prefix_chars": 0,
    "effective_random_suffix_chars": 5,
    "effective_search_space": "58^5"
  },
  "modes": {
    "validate_vectors": {
      "purpose": "Compare GPU implementation against Phase 0 public test vectors.",
      "input": {
        "test_vector_path": "tests/phase0_test_vectors.json"
      },
      "must_pass_before_benchmark": true
    },
    "benchmark": {
      "purpose": "Measure complete TRON address generation speed.",
      "preflight_tests": [
        "tests/verify_incremental_walking.cpp",
        "tests/verify_shard_schedule.cpp"
      ],
      "input": {
        "suffix": "five custom Base58 characters at the end of the address",
        "internal_target_address": "derived by Python wrapper for CUDA binary",
        "internal_prefix_len": 0,
        "internal_suffix_len": 5,
        "kernel_mode": "incremental or scalar; default incremental",
        "duration_seconds": "1..10 for first approved tests",
        "max_attempts": "positive cap for bounded smoke or benchmark run",
        "start_counter": "non-negative deterministic candidate offset",
        "shard_id": "0-based worker shard id",
        "shard_count": "total concurrent shards"
      },
      "output": {
        "attempts": "complete TRON addresses attempted",
        "addresses_per_second": "attempts / elapsed_seconds",
        "keys_per_second": "same as addresses_per_second",
        "kernel_mode": "benchmark implementation path",
        "matched": "boolean",
        "matched_address": "only if matched",
        "gpu_name": "reported by worker if available"
      },
      "gate": "blocked unless ALLOW_GPU_BENCHMARK=1 is explicitly set on approved RunPod endpoint",
      "forbidden_output": [
        "private_key",
        "mnemonic",
        "seed",
        "token",
        "secret"
      ]
    },
    "production": {
      "purpose": "Find a match and encrypt key material to customer age recipient.",
      "input": {
        "suffix": "five custom Base58 characters at the end of the address",
        "age_recipient": "customer age recipient public key beginning with age1",
        "duration_seconds": "bounded worker invocation, default/max 15 during production target",
        "max_attempts": "positive cap for bounded RunPod invocation",
        "start_counter": "non-negative deterministic candidate offset",
        "shard_id": "0-based worker shard id",
        "shard_count": "total concurrent shards"
      },
      "output": {
        "matched_address": "TRON address",
        "encrypted_private_key": "age encrypted private key"
      },
      "forbidden_output": [
        "plaintext private_key",
        "customer age identity",
        "token",
        "secret"
      ]
    }
  }
}
